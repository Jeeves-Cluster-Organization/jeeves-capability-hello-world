# ==============================================================================
# Jeeves Hello World - Environment Configuration
# ==============================================================================
#
# Usage:
#   cargo run
#
# LLM: GenAI provider (supports OpenAI, Anthropic, Gemini, Ollama, Groq, etc.)
# Model prefix determines provider: gpt-* → OpenAI, claude-* → Anthropic, etc.
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM PROVIDER
# ------------------------------------------------------------------------------
# Model name (prefix determines provider)
DEFAULT_MODEL=gpt-4o-mini

# API key for your chosen provider (set the one matching your model prefix)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
PORT=8001

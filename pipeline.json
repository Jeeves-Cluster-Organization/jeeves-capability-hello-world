{
  "$schema": "../jeeves-core/schema/pipeline.schema.json",
  "name": "onboarding_chatbot",
  "stages": [
    {
      "name": "understand",
      "agent": "understand",
      "has_llm": true,
      "model_role": "fast",
      "output_key": "understand",
      "prompt_key": "chatbot.understand",
      "temperature": 0.3,
      "max_tokens": 4000,
      "max_context_tokens": 8000,
      "context_overflow": "TruncateOldest",
      "timeout_seconds": 10,
      "retry_policy": {"max_retries": 1},
      "output_schema": {
        "type": "object",
        "properties": {
          "intent": {"type": "string"},
          "topic": {"type": "string"},
          "reasoning": {"type": "string"}
        },
        "required": ["intent"]
      },
      "routing_fn": "intent_router",
      "default_next": "think_knowledge",
      "error_next": "respond"
    },
    {
      "name": "think_knowledge",
      "agent": "think_knowledge",
      "has_llm": false,
      "output_key": "think_results",
      "allowed_tools": ["think_knowledge"],
      "timeout_seconds": 5,
      "default_next": "respond",
      "error_next": "respond"
    },
    {
      "name": "think_tools",
      "agent": "think_tools",
      "has_llm": false,
      "output_key": "think_results",
      "allowed_tools": ["think_tools", "get_time", "list_tools"],
      "timeout_seconds": 5,
      "default_next": "respond",
      "error_next": "respond"
    },
    {
      "name": "respond",
      "agent": "respond",
      "has_llm": true,
      "output_key": "respond",
      "prompt_key": "chatbot.respond",
      "temperature": 0.5,
      "max_tokens": 4000,
      "max_context_tokens": 8000,
      "context_overflow": "TruncateOldest",
      "timeout_seconds": 30,
      "retry_policy": {"max_retries": 1},
      "output_schema": {
        "type": "object",
        "properties": {
          "response": {"type": "string"},
          "needs_more_context": {"type": "boolean"}
        },
        "required": ["response"]
      },
      "max_visits": 3,
      "routing_fn": "respond_loop"
    }
  ],
  "max_iterations": 4,
  "max_llm_calls": 7,
  "max_agent_hops": 12,
  "state_schema": [
    {"key": "think_results", "merge": "Append"}
  ]
}
